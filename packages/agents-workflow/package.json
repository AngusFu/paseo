{
  "name": "@getpaseo/agents-workflow",
  "version": "0.1.105",
  "private": true,
  "description": "Deterministic multi-agent workflow engine (Claude-Code-Workflow superset) with SDK and aw CLI",
  "bin": {
    "aw": "./dist/cli.js"
  },
  "files": [
    "dist",
    "workflows",
    "workflow.d.ts",
    "README.md"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./cli": "./dist/cli.js"
  },
  "scripts": {
    "clean": "node ../../scripts/clean-package-dist.mjs",
    "build": "tsc -p tsconfig.json --incremental false",
    "build:clean": "npm run clean && npm run build",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "execa": "^9.6.1",
    "p-limit": "^7.3.0",
    "yargs-parser": "^22.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^20.17.9",
    "@types/yargs-parser": "^21.0.3",
    "@vitest/coverage-v8": "^4.1.6",
    "typescript": "^5.7.2",
    "vitest": "^4.1.6"
  }
}
